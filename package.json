{
  "name": "aura-toast",
  "version": "1.2.4",
  "homepage": "https://damicode18.github.io/aura-toast/",
  "description": "Premium React toast notifications with glassmorphism design. Lightweight, customizable, and enforces a single-toast constraint for clean UI.",
  "main": "dist/aura-toast.cjs.js",
  "module": "dist/aura-toast.es.js",
  "style": "dist/style.css",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode library && tsc-alias",
    "build:demo": "vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "predeploy": "npm run build:demo",
    "deploy": "gh-pages -d dist-demo"
  },
  "keywords": [
    "react-toast",
    "toast-notification",
    "react-component",
    "glassmorphism",
    "snackbar",
    "alert",
    "notification",
    "ui-library",
    "premium-ui"
  ],
  "author": "DamiCode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damicode18/aura-toast.git"
  },
  "bugs": {
    "url": "https://github.com/damicode18/aura-toast/issues"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/ui": "^4.1.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsc-alias": "^1.8.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
